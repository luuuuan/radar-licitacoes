# ===== Banco e fila (não precisa mexer se usar o docker-compose) =====
DATABASE_URL=postgresql+psycopg2://radar:radar@db:5432/radar
REDIS_URL=redis://redis:6379/0

# ===== PNCP (API pública — Lei 14.133/2021) =====
# Modalidades: 4=Concorrência Eletrônica, 6=Pregão Eletrônico, 8=Dispensa, 9=Inexigibilidade
PNCP_MODALIDADES=6,8,9,4
# UFs a monitorar (vazio = Brasil inteiro). Ex.: PR,SP,RJ,MG,BA
PNCP_UFS=PR,SP
# Buscar editais com propostas em aberto até X dias à frente
PNCP_HORIZONTE_DIAS=30

# ===== Pontuação (ajuste fino do match) =====
LIMIAR_FORTE=0.62
LIMIAR_MEDIO=0.40
LIMIAR_ITEM=0.35

# ===== Notificações por e-mail (opcional) =====
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
NOTIFICAR_EMAIL=voce@empresa.com

# ===== Notificações por Telegram (opcional) =====
# Crie um bot no @BotFather e pegue o chat_id em @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Só notifica deste nível pra cima: forte | medio
NOTIFICAR_NIVEL_MINIMO=forte
