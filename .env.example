# ===== Banco e fila (não precisa mexer se usar o docker-compose) =====
DATABASE_URL=postgresql+psycopg2://radar:radar@db:5432/radar
REDIS_URL=redis://redis:6379/0

# ===== Autenticação do painel (HTTP Basic) =====
# Se deixar em branco, o painel fica ABERTO (ok só para teste local).
# Em produção (Render), defina um usuário e senha — o navegador vai pedir login.
BASIC_AUTH_USER=
BASIC_AUTH_PASS=

# Chave para disparar a coleta diária via HTTP (a coleta roda no Render, que
# alcança o PNCP; o GitHub Actions só "cutuca" 1x/dia). Defina a MESMA chave
# aqui (no Render) e no secret CRON_SECRET do GitHub.
CRON_SECRET=

# ===== Autenticação do dashboard/API (HTTP Basic) =====
# Se preencher os dois, o navegador pede usuário/senha para acessar.
# Deixe vazio para ambiente local sem senha. (A rota /health fica sempre livre.)
BASIC_AUTH_USER=
BASIC_AUTH_PASS=

# ===== Segurança multiusuário =====
# Assina os tokens de sessão (JWT) e, se APP_ENCRYPTION_KEY ficar vazia,
# também deriva a cifra de CPF/CNPJ e chaves de API dos usuários.
# Local: pode deixar vazio (usa um valor de exemplo, só serve pra testar).
# Produção (Render): OBRIGATÓRIO gerar um valor próprio e aleatório — o
# render.yaml já faz isso sozinho (generateValue), não precisa copiar daqui.
# Gerar um valor forte localmente: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=
APP_ENCRYPTION_KEY=
# URL pública do app (ex.: https://radar-licitacoes.onrender.com). Usada nos
# links de e-mail (verificação/redefinição de senha) e pra marcar o cookie de
# sessão como "secure" — deixe vazio em desenvolvimento local.
APP_BASE_URL=

# ===== PNCP (API pública — Lei 14.133/2021) =====
# Modalidades: 4=Concorrência Eletrônica, 6=Pregão Eletrônico, 8=Dispensa, 9=Inexigibilidade
PNCP_MODALIDADES=6,8,9,4
# UFs a monitorar (vazio = Brasil inteiro). Ex.: PR,SP,RJ,MG,BA
PNCP_UFS=PR,SP
# Buscar editais com propostas em aberto até X dias à frente
PNCP_HORIZONTE_DIAS=30

# ===== Pontuação (ajuste fino do match) =====
LIMIAR_FORTE=0.62
LIMIAR_MEDIO=0.40
LIMIAR_ITEM=0.35
# Opcional: só classifica como "forte" se ao menos esta fração de itens bater
# (0 = desligado). Ex.: 0.1 = pelo menos 10% dos itens do edital.
FRACAO_MINIMA_FORTE=0
# Cobertura mínima p/ "forte" em matches fuzzy (0.05 = 5%). Código exato é isento.
FRACAO_MINIMA_FORTE=0.05

# ===== Notificações por e-mail (opcional) =====
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
NOTIFICAR_EMAIL=voce@empresa.com

# ===== Notificações por Telegram (opcional) =====
# Crie um bot no @BotFather e pegue o chat_id em @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Só notifica deste nível pra cima: forte | medio
NOTIFICAR_NIVEL_MINIMO=forte

# ===== Disparo da coleta via HTTP (cron externo) =====
# Defina uma chave secreta qualquer (ex.: uma senha longa). O GitHub Actions
# usa o MESMO valor para disparar /api/coletar-cron. Vazio = endpoint desativado.
CRON_SECRET=

# ===== IA semântica (Gemini embeddings) — OPCIONAL e gratuito =====
# Crie a chave no Google AI Studio (https://aistudio.google.com/apikey).
# Sem ela, a IA fica desligada e o sistema roda só com o matching textual.
GEMINI_API_KEY=
# peso da IA no score (0..1): 0.4 = 60% texto + 40% IA
IA_PESO=0.4
# piso de similaridade da IA (abaixo disso conta como 0)
IA_FLOOR=0.5
